# ── PolicyChecker — Environment Template ─────────────────────────────────
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# .env is gitignored; .env.example is tracked and safe to commit.

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Used by db/seed.py (populate demo entities) and db/rdf_converter.py
# Match these values with docker-compose.yml if running via Docker.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ait_database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Ollama (local LLM) ────────────────────────────────────────────────────
# Install Ollama: https://ollama.com/download
# Pull model:    ollama pull mistral
# The pipeline uses OLLAMA_MODEL for classification/FOL and
# OLLAMA_SECOND_MODEL for reclassification (can be the same model).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_SECOND_MODEL=mistral

# Seed for deterministic LLM sampling (set to any integer for reproducibility)
OLLAMA_SEED=42

# ── Pipeline ──────────────────────────────────────────────────────────────
# Human-readable version label embedded in pipeline_report.json
PIPELINE_VERSION=dev

# ── Feature flags ─────────────────────────────────────────────────────────
# Set EXTRACT_SPACY=1 to use spaCy sentencizer instead of regex extraction.
# Requires: pip install spacy && python -m spacy download en_core_web_sm
EXTRACT_SPACY=0

# ── LLM cache ─────────────────────────────────────────────────────────────
# Maximum number of cached LLM responses (SQLite-backed).
# Increase if you have many unique policy sentences.
CACHE_MAX_ENTRIES=2000

# ── Ablation study flags (advanced) ──────────────────────────────────────
# These are normally set by langgraph_agent/run.py --ablation flag.
# Only set manually if you know what you're doing.
# ABLATION_SKIP_PREFILTER=1
# ABLATION_NO_HINTS=1
# ABLATION_SKIP_RECLASSIFY=1
# ABLATION_SKIP_DIRECT_SHACL=1
# ABLATION_NO_FOL_RETRY=1
# ABLATION_NO_MAY_DISAMBIG=1
