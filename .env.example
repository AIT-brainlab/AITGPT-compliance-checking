PROJECT_NAME=policy-checker
POSTGRES_HOST=postgres
#POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aitgpt_cc_db
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpassword

OLLAMA_HOST=http://ollama:11434        # for devcontainer
# OLLAMA_HOST=http://localhost:11434     # for local development (without devcontainer), or change to any ollama endpoint
OLLAMA_MODEL=mistral
OLLAMA_SECOND_MODEL=mistral
OLLAMA_SEED=42

# Pipeline 
PIPELINE_VERSION=2.1-hints

# Extraction: set to 1 to use spaCy sentencizer instead of regex
EXTRACT_SPACY=0

# Cache 
CACHE_MAX_ENTRIES=2000
