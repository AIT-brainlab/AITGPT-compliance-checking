@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix ait:    <http://example.org/ait-policy#> .
@prefix deontic: <http://example.org/deontic#> .

# Rule: AIT-0000 | OBLIGATION
# FOL: O(about(author))
ait:AIT_0000Shape a sh:NodeShape ;
    sh:targetSubjectsOf ait:about ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0000Shape_prop1 .

ait:AIT_0000Shape_prop1 a sh:PropertyShape ;
    sh:path ait:about ;
    sh:minCount 1 ;
    sh:message "Authors must be responsible for what has been written in return for the credit and recognition that authorship brings." .

# Rule: AIT-0001 | OBLIGATION
# FOL: O(multiAuthoredArticleWrittenByStudentShouldBeFirstAuthorUnlessJournalRequiresDifferentOrder(agent))
ait:AIT_0001Shape a sh:NodeShape ;
    sh:targetClass ait:Student ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0001Shape_prop1 .

ait:AIT_0001Shape_prop1 a sh:PropertyShape ;
    sh:path ait:multiAuthoredArticleWrittenByStudentShouldBeFirstAuthorUnlessJournalRequiresDifferentOrder ;
    sh:minCount 1 ;
    sh:message "For any multi-authored article based on a student thesis, research study or dissertation, the student should normally be the first author, unless there is documented evidence that the journal required" .

# Rule: AIT-0002 | OBLIGATION
# FOL: O(correspondAsAuthorWithJournal(ChairOfStudentProgramCommittee))
ait:AIT_0002Shape a sh:NodeShape ;
    sh:targetClass ait:Student ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0002Shape_prop1 .

ait:AIT_0002Shape_prop1 a sh:PropertyShape ;
    sh:path ait:correspondAsAuthorWithJournal ;
    sh:minCount 1 ;
    sh:message "However, the Chair of the student’s Program Committee should serve as the corresponding author with any journal." .

# Rule: AIT-0004 | OBLIGATION
# FOL: O(reportIncidentOrPracticeToSchoolDeanOrVPA)(member_of_ait_community)
ait:AIT_0004Shape a sh:NodeShape ;
    sh:targetClass ait:Resident ;
    sh:severity sh:Violation ;
    sh:property ait:AIT_0004Shape_prop1 .

ait:AIT_0004Shape_prop1 a sh:PropertyShape ;
    sh:path ait:approved_by_president_or_vp_designate ;
    sh:minCount 1; sh:datatype xsd:string; sh:pattern "\\b[A-Z0-9]{6,12}\\b" ;
    sh:message "DISCIPLINARY ACTION Any member of the AIT community who is aware of academic misconduct in research or publication may report the incident or practice to the School Dean or directly to the Vice Presid" .

